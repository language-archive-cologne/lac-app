# Storage Configuration Examples
# ==========================

# Default workspace buckets (comma-separated list) - use actual bucket names
# S3_WORKSPACE_BUCKETS=lacos-ingest,lacos-production

# Example: Add more buckets to your workspace
# S3_WORKSPACE_BUCKETS=lacos-ingest,lacos-production,user-uploads,external-data,archive

# Buckets where OCFL operations are allowed (must be subset of workspace buckets)
# S3_OCFL_BUCKETS=lacos-ingest,lacos-production

# Example: Keep OCFL restricted to specific buckets while allowing file operations on others
# S3_OCFL_BUCKETS=lacos-ingest,lacos-production

# Legacy bucket names for backward compatibility
# S3_INGEST_BUCKET=lacos-ingest
# S3_PRODUCTION_BUCKET=lacos-production