# S3/MinIO Settings for Local Development
# ------------------------------------------------------------------------------
USE_MINIO=true
AWS_S3_ENDPOINT_URL=http://minio:9000
# This is the URL that browsers will use to connect to MinIO
AWS_S3_BROWSER_ENDPOINT_URL=http://localhost:9100
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=lacos-ingest
AWS_PRODUCTION_BUCKET_NAME=lacos-production
AWS_S3_REGION_NAME=eu-central-1

# Multipart Upload Configuration (matches arkumu)
# 5GB threshold - forces single uploads for most files
MULTIPART_THRESHOLD=5368709120