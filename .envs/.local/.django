# General
# ------------------------------------------------------------------------------
USE_DOCKER=yes
IPYTHONDIR=/app/.ipython

# COLLECTION PATH STRUCTURE CONFIGURATION
# ======================================================

# Base path patterns - Use Python-style string format placeholders
COLLECTION_PATH_PATTERN={collection_id}/{collection_id}
BUNDLE_PATH_PATTERN={collection_id}/{bundle_id}
# Resource and XML paths are explicitly defined
RESOURCE_PATH_PATTERN={collection_id}/{bundle_id}/v1/content/data/{resource_filename}
COLLECTION_XML_PATH={collection_id}/{collection_id}/v1/content/{collection_id}.xml
BUNDLE_XML_PATH={collection_id}/{bundle_id}/v1/content/{bundle_id}.xml

# Database backup (Huey - local/MinIO)
# ------------------------------------------------------------------------------
DB_BACKUP_ENABLED=true
DB_BACKUP_COMPOSE_FILE=docker-compose.local.yml
DB_BACKUP_COMPOSE_PROJECT_DIR=/app
DB_BACKUP_COMPOSE_PROJECT_NAME=lac-app
DB_BACKUP_BACKUP_DIR=/backups
DB_BACKUP_S3_BUCKET=backups
DB_BACKUP_S3_PREFIX=db-backups
DB_BACKUP_RETENTION_DAYS=7
DB_BACKUP_CRON_HOUR=2
DB_BACKUP_CRON_MINUTE=0
HUEY_IMMEDIATE=false
